# 前端鉴权模式配置(Vite 环境变量,VITE_ 前缀才会打进产物)。
#
# 生效方式:
#   - dev(pnpm dev,:5173):读 .env.development / .env.local(改后重启 dev)
#   - 容器构建(:8088):由 Dockerfile build arg 注入(见 docker-compose.idp.yml / docker-compose.dual.yml)
#
# 复制本文件为 .env.local 可覆盖本机 dev 默认。

# 鉴权模式:password(默认,账号密码 HS256)| idp(纯 SSO)| dual(两者一页共存)
VITE_AUTH_MODE=dual

# idp/dual 模式:his-idp issuer(浏览器可达地址)
VITE_OIDC_AUTHORITY=http://localhost:9008

# OIDC 客户端 id(与 his-idp 注册的 RegisteredClient 一致)
VITE_OIDC_CLIENT_ID=his-web
