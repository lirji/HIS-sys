{
  "uid": "his-overview",
  "title": "HIS 平台总览",
  "tags": ["his", "micrometer", "spring-boot"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "instance",
        "label": "服务实例",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(up{job=\"his-services\"}, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "服务在线",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ] }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "expr": "up{job=\"his-services\", instance=~\"$instance\"}", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP 请求速率 (req/s)",
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (instance) (rate(http_server_requests_seconds_count{instance=~\"$instance\"}[1m]))", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP P95 延迟 (s)",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, instance) (rate(http_server_requests_seconds_bucket{instance=~\"$instance\"}[5m])))", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "JVM 堆内存使用 (bytes)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (instance) (jvm_memory_used_bytes{area=\"heap\", instance=~\"$instance\"})", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "进程 CPU 使用率",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "process_cpu_usage{instance=~\"$instance\"}", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP 5xx 错误速率 (req/s)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (instance) (rate(http_server_requests_seconds_count{status=~\"5..\", instance=~\"$instance\"}[1m]))", "legendFormat": "{{instance}}" }
      ]
    }
  ]
}
